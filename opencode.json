{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "autostock": {
      "type": "local",
      "command": ["bun", "run", "../src/mcp-server.ts"]
    }
  },
  "permission": {
    "*": "deny",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "autostock_steer": "ask",
    "autostock_steer_read": "allow"
  }
}
