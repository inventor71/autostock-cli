{
  // Project opencode override — wires the autostock steering MCP + the default-deny
  // lockdown. Committed & portable: paths come from {env:AUTOSTOCK_ROOT} and the token
  // from {env:STEERING_OPERATOR_TOKEN} (opencode substitutes {env:...} across the whole
  // config before parsing), so no machine path or secret is baked in.
  //
  // The operator exports both before launch (they live in the gitignored cli/.env):
  //   set -a; . ./.env; set +a    # AUTOSTOCK_ROOT, STEERING_DIR, STEERING_OPERATOR_TOKEN
  //   bun dev
  //
  // WHY absolute paths (via AUTOSTOCK_ROOT): `bun dev` runs opencode with cwd
  // packages/opencode, and the local-MCP subprocess inherits that cwd. A relative
  // command path (../src/...) resolves to packages/src and fails ("Module not found"),
  // which leaves autostock_steer unregistered — the model then says it "can't place
  // orders" because the tool is absent, not denied. An absolute command path fixes it.
  "mcp": {
    "autostock": {
      "type": "local",
      "command": ["bun", "run", "{env:AUTOSTOCK_ROOT}/operator-console/src/mcp-server.ts"],
      "environment": {
        "STEERING_DIR": "{env:AUTOSTOCK_ROOT}/steering",
        "STEERING_OPERATOR_TOKEN": "{env:STEERING_OPERATOR_TOKEN}"
      }
    }
  },
  "permission": {
    "*": "deny",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "autostock_steer": "ask",
    "autostock_steer_read": "allow"
  }
}
